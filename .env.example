# ============================================================
# Financial Research Analysis System - Environment Template
# Copy to .env and fill values
# ============================================================

# ---- Database (MySQL 8 primary) ----
USE_SQLITE=false
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=financial_research

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ---- LLM / Ollama ----
DEV_MODE=false
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
LLM_MODEL=qwen2.5:latest
EMBEDDING_MODEL=embeddinggemma:latest

# Optional cloud fallbacks
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ---- Auth ----
JWT_SECRET=change-me
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
USER_USERNAME=user
USER_PASSWORD=user123

# ---- Service ----
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
FLASK_PORT=5001
DEBUG=true

# ---- Proxy for slow downloads (pip/npm/model pulls) ----
HTTP_PROXY=http://127.0.0.1:7897
HTTPS_PROXY=http://127.0.0.1:7897

# ---- RAG defaults ----
RAG_TOP_K=5
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=120
RAG_SCORE_THRESHOLD=0.15
RAG_ENABLED=true
