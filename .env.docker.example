# 复制为 .env 可供 docker compose 读取（可选，有默认值）
# Windows: copy .env.docker.example .env

WEB_PORT=8080

MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=financial_research
MYSQL_USER=fras
MYSQL_PASSWORD=fras123

JWT_SECRET=please-change-this-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
USER_USERNAME=user
USER_PASSWORD=user123

LLM_MODEL=qwen2.5:latest
EMBEDDING_MODEL=embeddinggemma:latest

# ---------- 复用本机已下载的 Ollama 模型（推荐，避免重复下载）----------
# 方式 A：挂载本机模型目录到容器（路径按自己机器改）
# Windows 示例:
# OLLAMA_MODELS_DIR=C:\Users\你的用户名\.ollama
# Linux/macOS 示例:
# OLLAMA_MODELS_DIR=/home/你的用户名/.ollama
#
# 方式 B：直接使用本机正在运行的 Ollama 服务（不走容器内模型文件）
# OLLAMA_BASE_URL=http://host.docker.internal:11434
